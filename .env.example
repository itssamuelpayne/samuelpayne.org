# Copy to .env.local for local development.
# In production, set these in the Vercel dashboard:
#   Settings → Environment Variables

# The actual password visitors enter at /work.
WORK_PASSWORD=

# A long random secret used to sign the session cookie.
# Generate with: openssl rand -hex 32
# Treat this like a database password — never commit it.
# Rotating it will sign everyone out (they'll need to re-enter the password).
COOKIE_SECRET=
